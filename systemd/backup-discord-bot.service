[Unit]
Description=Discord backup bot
Wants=network-online.target
After=network-online.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=evelyn
Group=evelyn
WorkingDirectory=/home/evelyn/backups
ExecStart=/usr/local/bin/python3 /home/evelyn/backups/app.py
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
